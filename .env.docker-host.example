# Environment variables for connecting to host PostgreSQL
# Use this if you want to connect to PostgreSQL running on your host machine
# Copy this file to .env.docker-host and fill in your actual values

DATABASE_URL=postgresql://username@host.docker.internal:5432/yahooquiz
GROQ_API_KEY=your-groq-api-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
SECRET_KEY=your-secret-key-change-this-in-production
PORT=8080
FLASK_ENV=production
FLASK_DEBUG=0
